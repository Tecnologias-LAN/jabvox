<% content_for(:title) { "Saldo Config – #{@account.name}" } %>

<header class="main-content__header" role="banner">
  <h1 class="main-content__page-title">
    Saldo Config — <%= @account.name %>
  </h1>
  <%= link_to 'Back to Account', super_admin_account_path(@account), class: 'button' %>
</header>

<section class="main-content__body">
  <% if notice %>
    <p class="flash flash--notice"><%= notice %></p>
  <% end %>

  <div style="margin-bottom:24px; padding:16px; background:#f9fafb; border:1px solid #e5e7eb; border-radius:8px;">
    <h3 style="margin-bottom:12px; font-weight:600;">Saldo</h3>

    <%= form_with model: @config,
      url: super_admin_account_jabvox_saldo_config_path(@account),
      method: :patch do |f| %>
      <div style="display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap:12px; max-width:980px;">
        <div>
          <%= f.label :name_jabvox, 'Nombre', style: 'display:block; font-size:12px; font-weight:500; margin-bottom:4px;' %>
          <%= f.text_field :name_jabvox, style: 'width:100%; border:1px solid #d1d5db; border-radius:6px; padding:8px 12px; font-size:14px;' %>
        </div>
        <div>
          <%= f.label :proxy_url_jabvox, 'URL del Proxy', style: 'display:block; font-size:12px; font-weight:500; margin-bottom:4px;' %>
          <%= f.text_field :proxy_url_jabvox, placeholder: 'http://voip.t-lan.co/mb-proxy.php', style: 'width:100%; border:1px solid #d1d5db; border-radius:6px; padding:8px 12px; font-size:14px;' %>
        </div>
        <div>
          <%= f.label :api_key_jabvox, 'API Key', style: 'display:block; font-size:12px; font-weight:500; margin-bottom:4px;' %>
          <%= f.text_field :api_key_jabvox, style: 'width:100%; border:1px solid #d1d5db; border-radius:6px; padding:8px 12px; font-size:14px;' %>
        </div>
        <div>
          <%= f.label :api_secret_jabvox, 'API Secret', style: 'display:block; font-size:12px; font-weight:500; margin-bottom:4px;' %>
          <%= f.password_field :api_secret_jabvox, placeholder: (@config.persisted? ? 'Dejar en blanco para mantener el actual' : ''), style: 'width:100%; border:1px solid #d1d5db; border-radius:6px; padding:8px 12px; font-size:14px;' %>
        </div>
      </div>

      <div style="display:flex; gap:18px; margin-top:14px; align-items:center;">
        <div style="display:flex; align-items:center; gap:6px;">
          <%= f.check_box :is_active_jabvox %>
          <%= f.label :is_active_jabvox, 'Activo', style: 'font-size:12px; font-weight:500;' %>
        </div>
      </div>

      <div style="margin-top:16px;">
        <%= f.submit 'Guardar', class: 'button', style: 'cursor:pointer;' %>
      </div>
    <% end %>
  </div>

  <%
    balance = @status[:balance].to_f
    saldo_color = balance <= 10_000 ? '#ef4444' : (balance < 50_000 ? '#f97316' : '#2563eb')
    saldo_bg    = balance <= 10_000 ? '#fef2f2' : (balance < 50_000 ? '#fff7ed' : '#eff6ff')
    saldo_border = balance <= 10_000 ? '#fecaca' : (balance < 50_000 ? '#fed7aa' : '#bfdbfe')
  %>
  <div style="padding:20px 24px; background:<%= saldo_bg %>; border:1px solid <%= saldo_border %>; border-radius:8px; max-width:980px; display:flex; align-items:center; justify-content:space-between;">
    <div>
      <p style="font-size:13px; font-weight:500; color:#6b7280; margin:0 0 4px;">Estado de conexión</p>
      <p style="font-size:13px; color:#374151; margin:0;"><%= @status[:message] %></p>
    </div>
    <div style="text-align:right;">
      <p style="font-size:12px; color:#6b7280; margin:0 0 4px;"><%= @status[:connected] ? 'Conectado' : 'Sin conexión (último valor)' %></p>
      <span style="font-size:28px; font-weight:800; color:<%= saldo_color %>;">
        $<%= number_with_delimiter(balance.round(0)) %>
      </span>
      <span style="font-size:13px; color:<%= saldo_color %>; margin-left:4px;"><%= @status[:currency] %></span>
    </div>
  </div>
</section>
