<%= form_with model: [:super_admin, role], local: true do |f| %>
  <% if role.errors.any? %>
    <div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:6px;padding:12px;margin-bottom:16px;">
      <ul style="margin:0;padding-left:16px;">
        <% role.errors.full_messages.each do |msg| %>
          <li style="color:#b91c1c;font-size:14px;"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% unless role.persisted? %>
    <div style="margin-bottom:24px;">
      <p style="font-size:13px;font-weight:600;color:#374151;margin:0 0 10px;">Ejemplos de roles</p>
      <p style="font-size:12px;color:#6b7280;margin:0 0 10px;">Haz click en uno para usarlo como punto de partida.</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px;">

        <% [
          {
            name: 'Atención al Cliente',
            prompt: "Tu rol es brindar atención al cliente de forma amable y eficiente.\n\nEscucha activamente las necesidades del usuario, resuelve sus dudas con claridad y escala a un agente humano cuando el caso lo requiera.\n\nMantén siempre un tono empático y profesional."
          },
          {
            name: 'Soporte Técnico',
            prompt: "Tu rol es dar soporte técnico paso a paso.\n\nAyuda al usuario a diagnosticar y resolver problemas técnicos. Solicita información adicional cuando sea necesario.\n\nSi el problema requiere acceso interno o es muy complejo, transfiere al soporte especializado."
          },
          {
            name: 'Agente de Ventas',
            prompt: "Tu rol es acompañar al cliente en su proceso de compra.\n\nIdentifica sus necesidades, presenta las opciones más adecuadas y guíalo hacia la decisión de compra. Resuelve objeciones con datos concretos.\n\nSé proactivo pero no insistente."
          },
          {
            name: 'Cobros y Pagos',
            prompt: "Tu rol es gestionar consultas sobre cobros, pagos y facturación.\n\nAyuda al usuario con el estado de sus pagos, métodos disponibles y resolución de discrepancias.\n\nMantén un tono neutral y profesional. Para casos de disputa, escala al área de finanzas."
          }
        ].each do |example| %>
          <button
            type="button"
            onclick="fillRoleExample(this)"
            data-name="<%= example[:name] %>"
            data-prompt="<%= example[:prompt] %>"
            style="text-align:left;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:10px 12px;cursor:pointer;transition:background .15s;"
            onmouseover="this.style.background='#eff6ff';this.style.borderColor='#93c5fd';"
            onmouseout="this.style.background='#f9fafb';this.style.borderColor='#e5e7eb';"
          >
            <p style="font-size:13px;font-weight:600;color:#1d4ed8;margin:0 0 3px;"><%= example[:name] %></p>
            <p style="font-size:11px;color:#6b7280;margin:0;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;"><%= example[:prompt].split("\n").first %></p>
          </button>
        <% end %>
      </div>
    </div>
    <script>
      function fillRoleExample(btn) {
        document.getElementById('role_name').value = btn.dataset.name;
        document.getElementById('role_prompt').value = btn.dataset.prompt;
      }
    </script>
  <% end %>

  <div style="margin-bottom:16px;">
    <%= f.label :name_jabvox, 'Nombre del Rol', style: 'display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:4px;' %>
    <%= f.text_field :name_jabvox, id: 'role_name', placeholder: 'ej. Atención al Cliente',
        style: 'width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:6px;font-size:14px;' %>
  </div>

  <div style="margin-bottom:16px;">
    <%= f.label :prompt_jabvox, 'System Prompt del Rol', style: 'display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:4px;' %>
    <p style="font-size:12px;color:#6b7280;margin:0 0 6px;">
      Define el rol y comportamiento del agente IA. Se combina con el acento seleccionado.
    </p>
    <%= f.text_area :prompt_jabvox, id: 'role_prompt', rows: 10,
        placeholder: 'Tu rol es brindar atención al cliente de forma amable y profesional...',
        style: 'width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:6px;font-size:14px;font-family:monospace;resize:vertical;' %>
  </div>

  <div style="margin-bottom:24px;display:flex;align-items:center;gap:8px;">
    <%= f.check_box :active_jabvox, style: 'width:16px;height:16px;' %>
    <%= f.label :active_jabvox, 'Activo (disponible para las cuentas)', style: 'font-size:14px;color:#374151;' %>
  </div>

  <div style="display:flex;gap:8px;">
    <%= f.submit role.persisted? ? 'Actualizar Rol' : 'Crear Rol',
        style: 'background:#1f64e7;color:white;border:none;border-radius:6px;padding:10px 20px;font-size:14px;font-weight:600;cursor:pointer;' %>
    <%= link_to 'Cancelar', super_admin_jabvox_response_bot_seats_path + '#roles',
        style: 'background:#f3f4f6;color:#374151;border:1px solid #d1d5db;border-radius:6px;padding:10px 20px;font-size:14px;font-weight:600;text-decoration:none;' %>
  </div>
<% end %>
