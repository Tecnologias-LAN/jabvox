<%#
# Navigation

This partial is used to display the navigation in Administrate.
By default, the navigation contains navigation links
for all resources in the admin dashboard,
as defined by the routes in the `admin/` namespace
%>

<%= vite_client_tag %>
<%= vite_javascript_tag 'superadmin_pages' %>

<%
  sidebar_icons = {
    accounts: 'icon-building-4-line',
    users: 'icon-user-follow-line',
    platform_apps: 'icon-apps-2-line',
    agent_bots: 'icon-robot-line',
  }
%>

<div class="border-r border-[#8FC4C2] w-56 flex-shrink-0 h-full flex flex-col bg-gradient-to-b from-[#DAEBDB] to-[#A8D5D3]" role="navigation">

  <!-- Logo fijo arriba -->
  <div class="flex-shrink-0 flex mx-4 mb-2 border-[#8FC4C2]/60 border-b py-5">
    <%= link_to image_tag('/jabvox/public/logo.png', alt: 'Jabvox', class: 'h-8 w-auto'), super_admin_root_url %>
    <div class="flex flex-col ml-3">
      <div class="text-sm font-semibold text-[#15605A]">Jabvox</div>
      <div class="text-xs text-[#2d5a52] mt-0.5">Super Admin</div>
    </div>
  </div>

  <!-- Menú central scrollable -->
  <div class="flex-1 overflow-y-auto min-h-0">
    <ul class="py-2">
      <%= render partial: "nav_item", locals: { icon: 'icon-grid-line', url: super_admin_root_url, label: 'Dashboard' } %>
      <% Administrate::Namespace.new(namespace).resources.each do |resource| %>
        <% next if ["account_users", "access_tokens", "installation_configs", "dashboard", "devise/sessions", "app_configs", "instance_statuses", "settings", "push_diagnostics", "jabvox_ip_whitelists", "jabvox_saldo_configs", "jabvox_user_extensions", "jabvox_response_bot_roles"].include? resource.resource %>
        <%= render partial: "nav_item", locals: {
            icon: sidebar_icons[resource.resource.to_sym],
            url: resource_index_route(resource),
            label: display_resource_name(resource),
          }
        %>
      <% end %>
      <%= render partial: "nav_item", locals: { icon: 'icon-wallet-line', url: super_admin_jabvox_saldo_configs_url, label: 'Saldo VoIP' } %>
      <%= render partial: "nav_item", locals: { icon: 'icon-robot-line', url: super_admin_jabvox_response_bot_seats_url, label: 'Response Bot' } %>
      <%= render 'settings_menu', open: settings_open? %>
    </ul>
  </div>

  <!-- Links utilitarios fijos abajo -->
  <div class="flex-shrink-0 border-t border-[#8FC4C2]/60">
    <ul class="py-2">
      <%= render partial: "nav_item", locals: { icon: 'icon-mist-fill', url: sidekiq_web_url, label: 'Sidekiq Dashboard' } %>
      <%= render partial: "nav_item", locals: { icon: 'icon-health-book-line', url: super_admin_instance_status_url, label: 'Instance Health' } %>
      <%= render partial: "nav_item", locals: { icon: 'icon-mail-send-fill', url: super_admin_push_diagnostics_url, label: 'Push Diagnostics' } %>
      <%= render partial: "nav_item", locals: { icon: 'icon-dashboard-line', url: '/', label: 'Agent Dashboard' } %>
      <%= render partial: "nav_item", locals: { icon: 'icon-logout-circle-r-line', url: super_admin_logout_url, label: 'Logout' } %>
    </ul>
  </div>

</div>
