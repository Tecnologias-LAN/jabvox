<% content_for(:title) { "Extensions – #{@account.name}" } %>

<header class="main-content__header" role="banner">
  <h1 class="main-content__page-title">Extensions — <%= @account.name %></h1>
  <%= link_to 'Back to Account', super_admin_account_path(@account), class: 'button' %>
</header>

<section class="main-content__body">
  <% if notice %>
    <p class="flash flash--notice"><%= notice %></p>
  <% end %>

  <% if @entry&.errors&.any? %>
    <div style="margin-bottom:16px; padding:12px 16px; background:#fef2f2; border:1px solid #fecaca; border-radius:8px; color:#991b1b; font-size:13px;">
      <% @entry.errors.full_messages.each do |msg| %>
        <p style="margin:0;"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div style="margin-bottom:24px; padding:16px; background:#f9fafb; border:1px solid #e5e7eb; border-radius:8px;">
    <h3 style="margin-bottom:12px; font-weight:600;">Assign Extension</h3>
    <%= form_with url: super_admin_account_jabvox_user_extensions_path(@account), method: :post do |f| %>
      <div style="display:flex; gap:12px; align-items:flex-end; flex-wrap:wrap;">
        <div>
          <%= f.label :user_id, 'User', style: 'display:block; font-size:12px; font-weight:500; margin-bottom:4px;' %>
          <%= f.select 'jabvox_user_extension[user_id]',
                @account_users.reject { |u| @used_user_ids.include?(u.id) }.map { |u| [u.name + ' (' + u.email + ')', u.id] },
                { prompt: 'Select user...' },
                style: 'border:1px solid #d1d5db; border-radius:6px; padding:8px 12px; font-size:14px; min-width:260px;' %>
        </div>
        <div>
          <%= f.label :extension_jabvox, 'Extension', style: 'display:block; font-size:12px; font-weight:500; margin-bottom:4px;' %>
          <%= f.text_field 'jabvox_user_extension[extension_jabvox]',
                placeholder: 'e.g. 101',
                style: 'border:1px solid #d1d5db; border-radius:6px; padding:8px 12px; font-size:14px; width:120px;' %>
        </div>
        <%= f.submit 'Add', class: 'button', style: 'cursor:pointer;' %>
      </div>
    <% end %>
  </div>

  <% if @extensions.empty? %>
    <p style="color:#6b7280; font-size:14px;">No extensions configured. Users will be prompted to enter their extension when making calls.</p>
  <% else %>
    <table style="width:100%; border-collapse:collapse; font-size:14px;">
      <thead>
        <tr style="background:#f3f4f6; text-align:left;">
          <th style="padding:10px 14px; border-bottom:1px solid #e5e7eb;">User</th>
          <th style="padding:10px 14px; border-bottom:1px solid #e5e7eb;">Email</th>
          <th style="padding:10px 14px; border-bottom:1px solid #e5e7eb;">Extension</th>
          <th style="padding:10px 14px; border-bottom:1px solid #e5e7eb;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @extensions.each do |ext| %>
          <tr style="border-bottom:1px solid #f3f4f6;">
            <td style="padding:10px 14px; font-weight:500;"><%= ext.user.name %></td>
            <td style="padding:10px 14px; color:#6b7280;"><%= ext.user.email %></td>
            <td style="padding:10px 14px;">
              <span style="display:inline-block; padding:2px 12px; border-radius:12px; font-size:13px; font-weight:700; background:#eff6ff; color:#1d4ed8; font-family:monospace;">
                <%= ext.extension_jabvox %>
              </span>
            </td>
            <td style="padding:10px 14px;">
              <%= button_to 'Remove',
                    super_admin_account_jabvox_user_extension_path(@account, ext),
                    method: :delete,
                    data: { confirm: "Remove extension #{ext.extension_jabvox} from #{ext.user.name}?" },
                    style: 'cursor:pointer; padding:4px 10px; border-radius:4px; font-size:12px; border:1px solid #fca5a5; background:#fee2e2; color:#991b1b;' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>
