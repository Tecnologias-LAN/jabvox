<div style="max-width:900px;margin:0 auto;padding:24px;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
    <div>
      <h1 style="font-size:22px;font-weight:700;color:#111827;margin:0;">Response Bot — Acentos</h1>
      <p style="font-size:14px;color:#6b7280;margin:4px 0 0;">
        Manage AI bot acentos available to all accounts. Each acento has a system prompt that defines the bot's behavior.
      </p>
    </div>
    <%= link_to '+ New Acento', new_super_admin_jabvox_response_bot_seat_path,
        style: 'background:#1f64e7;color:white;border-radius:6px;padding:10px 18px;font-size:14px;font-weight:600;text-decoration:none;' %>
  </div>

  <% if @seats.empty? %>
    <div style="text-align:center;padding:48px;background:#f9fafb;border:1px solid #e5e7eb;border-radius:10px;">
      <p style="color:#6b7280;font-size:14px;">No acentos yet. Create the first one.</p>
    </div>
  <% else %>
    <table style="width:100%;border-collapse:collapse;background:white;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;">
      <thead>
        <tr style="background:#f9fafb;border-bottom:1px solid #e5e7eb;">
          <th style="text-align:left;padding:12px 16px;font-size:12px;font-weight:600;color:#6b7280;text-transform:uppercase;">Name</th>
          <th style="text-align:left;padding:12px 16px;font-size:12px;font-weight:600;color:#6b7280;text-transform:uppercase;">Prompt (preview)</th>
          <th style="text-align:center;padding:12px 16px;font-size:12px;font-weight:600;color:#6b7280;text-transform:uppercase;">Status</th>
          <th style="text-align:right;padding:12px 16px;font-size:12px;font-weight:600;color:#6b7280;text-transform:uppercase;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @seats.each do |seat| %>
          <tr style="border-bottom:1px solid #f3f4f6;">
            <td style="padding:14px 16px;font-size:14px;font-weight:600;color:#111827;"><%= seat.name_jabvox %></td>
            <td style="padding:14px 16px;font-size:13px;color:#4b5563;max-width:360px;">
              <%= truncate(seat.prompt_jabvox.to_s, length: 100) %>
            </td>
            <td style="padding:14px 16px;text-align:center;">
              <% if seat.active_jabvox %>
                <span style="background:#d1fae5;color:#065f46;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;">Active</span>
              <% else %>
                <span style="background:#f3f4f6;color:#6b7280;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;">Inactive</span>
              <% end %>
            </td>
            <td style="padding:14px 16px;text-align:right;">
              <div style="display:flex;gap:8px;justify-content:flex-end;">
                <%= link_to 'Edit', edit_super_admin_jabvox_response_bot_seat_path(seat),
                    style: 'font-size:13px;color:#1f64e7;text-decoration:none;font-weight:500;' %>
                <%= button_to 'Delete', super_admin_jabvox_response_bot_seat_path(seat),
                    method: :delete,
                    data: { confirm: "Delete acento '#{seat.name_jabvox}'? This cannot be undone." },
                    style: 'background:none;border:none;color:#ef4444;font-size:13px;cursor:pointer;font-weight:500;' %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
